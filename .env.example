# Single local source for FastAPI, Telegram bot, and app.migrate.
# Copy to C:/PullUpBot/.env. Never commit the resulting .env.
APVITE_PULLUP_SITE_URL=https://pullup-sport.vercel.app
P_NAME=PULLUP API
APP_ENV=development

# Вариант 1: готовый URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Вариант 2: отдельные поля для локальной разработки.
# Если DATABASE_URL остаётся шаблонным, loader соберёт URL из этих DB_*.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=pullup
DB_USER=postgres
DB_PASSWORD=your_password

# Не оставляйте DATABASE_URL с шаблоном HOST:PORT в рабочем .env.
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_id
WEBAPP_URL=https://pullupbot.vercel.app
API_URL=https://your-backend.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://pullupbot.vercel.app,https://pullupbot-proruner13-pixels-projects.vercel.app,https://pullupbot-proruner13-pixel-proruner13-pixels-projects.vercel.app,https://pullup.vercel.app,https://pullup-proruner13-pixels-projects.vercel.app,https://pullup-dun.vercel.app,https://pullup-proruner13-pixel-proruner13-pixels-projects.vercel.app,https://pullup-backend-dtxl.onrender.com
TELEGRAM_AUTH_MAX_AGE=86400
BOT_PUBLIC_URL=https://t.me/ActiveRunBot
SUPPORT_URL=https://t.me/ActiveRunBot
WEBAPP_DEEP_LINKS_ENABLED=false

# Vite reads this at build time. Use localhost only for local development.
VITE_API_URL=https://pullup-backend-dtxl.onrender.com
