# Local backend settings are loaded only from C:/PullUpBot/.env.
# This file documents the variables to configure in a production host.
# Render injects PORT automatically; do not set PORT manually.
APP_NAME=PULLUP API
APP_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_id
CORS_ORIGINS=https://pullupbot.vercel.app
WEBAPP_URL=https://pullupbot.vercel.app
TELEGRAM_AUTH_MAX_AGE=86400
PYTHON_VERSION=3.13.5
